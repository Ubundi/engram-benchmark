{
  "session_types": {
    "heartbeat": {
      "agent": "main",
      "message_range": [8, 12],
      "description": "Recurring task checks with status reporting and follow-up actions",
      "arc": [
        {"phase": "trigger", "role": "user", "template": "[Heartbeat] Execute recurring task checks for {time} SAST"},
        {"phase": "status_report", "role": "assistant", "template": "Heartbeat check at {time} SAST.\n\n**Status Overview:**\n{status_items}\n\n**Tasks Ran:**\n{tasks_ran}\n\n**Issues:**\n{issues}"},
        {"phase": "follow_up", "role": "user", "template": "{follow_up_question}"},
        {"phase": "detail", "role": "assistant", "template": "{detailed_response}"},
        {"phase": "instruction", "role": "user", "template": "{new_instruction}"},
        {"phase": "execution", "role": "assistant", "template": "{execution_result}"},
        {"phase": "lesson", "role": "assistant", "template": "**Lesson:** {lesson_learned}"}
      ],
      "content_domains": [
        "social_monitoring_status", "task_staleness", "browser_auth",
        "sub_agent_status", "cost_tracking", "circuit_breaker_state",
        "recurring_task_results", "display_status_update"
      ],
      "fact_density": "high",
      "typical_facts": ["task_status", "metric_values", "blocking_issues", "timestamps", "agent_states"]
    },

    "design_planning": {
      "agent": "main",
      "message_range": [10, 20],
      "description": "Collaborative design sessions for new features, skills, or architecture",
      "arc": [
        {"phase": "propose", "role": "user", "template": "I want to {goal}. Let's design {feature_name}."},
        {"phase": "initial_design", "role": "assistant", "template": "Great idea! Here's my initial design for {feature_name}:\n\n{design_outline}"},
        {"phase": "feedback", "role": "user", "template": "{refinement_request}"},
        {"phase": "expand", "role": "assistant", "template": "{expanded_design}"},
        {"phase": "technical_question", "role": "user", "template": "{technical_question}"},
        {"phase": "technical_answer", "role": "assistant", "template": "{technical_response}"},
        {"phase": "refine", "role": "user", "template": "{refinement_instruction}"},
        {"phase": "refined_design", "role": "assistant", "template": "{refined_design_with_decisions}"},
        {"phase": "approve", "role": "user", "template": "{approval_with_modifications}"},
        {"phase": "implement", "role": "assistant", "template": "Done. {implementation_summary}\n\n**Files created/modified:**\n{file_list}\n\n**Design decisions:**\n{decisions}"}
      ],
      "content_domains": [
        "skill_design", "agent_architecture", "integration_setup",
        "workflow_design", "config_changes", "feature_planning",
        "benchmark_design", "dashboard_spec"
      ],
      "fact_density": "very_high",
      "typical_facts": ["design_decisions", "config_values", "architecture_choices", "file_paths", "rationale"]
    },

    "inbox_review": {
      "agent": "main",
      "message_range": [8, 14],
      "description": "Email inbox scanning, triage, and action item execution",
      "arc": [
        {"phase": "scan_request", "role": "user", "template": "Check my inbox for important emails."},
        {"phase": "scan_results", "role": "assistant", "template": "Checking inbox...\n\n**Important emails found:**\n{email_summaries}\n\n**Recommended actions:**\n{recommended_actions}"},
        {"phase": "triage", "role": "user", "template": "{triage_instructions}"},
        {"phase": "task_creation", "role": "assistant", "template": "{task_creation_results}"},
        {"phase": "action_instruction", "role": "user", "template": "{action_instruction}"},
        {"phase": "action_execution", "role": "assistant", "template": "{action_result}"},
        {"phase": "follow_up", "role": "user", "template": "{follow_up}"},
        {"phase": "completion", "role": "assistant", "template": "{completion_summary}"}
      ],
      "content_domains": [
        "investor_communications", "team_requests", "external_partnerships",
        "customer_feedback", "vendor_updates", "meeting_scheduling"
      ],
      "fact_density": "high",
      "typical_facts": ["email_senders", "email_dates", "action_items", "company_names", "amounts"]
    },

    "social_monitoring": {
      "agent": "engage_x",
      "message_range": [10, 18],
      "description": "Social platform scanning, engagement identification, and reply drafting",
      "arc": [
        {"phase": "task_assignment", "role": "user", "template": "[Subagent Task]: Social Engagement Tasks ({time} heartbeat):\n\n{task_list}"},
        {"phase": "identity", "role": "assistant", "template": "I'm engage-x, the social engagement sub-agent.\n\n**My personality (from SOUL.md):**\n{personality_summary}\n\n**Starting browser...**"},
        {"phase": "posting", "role": "assistant", "template": "**Posting Phase:**\n{posting_results}"},
        {"phase": "monitoring_scan", "role": "assistant", "template": "**Monitoring Phase — New Cards Submitted:**\n{new_cards}"},
        {"phase": "theme_analysis", "role": "assistant", "template": "**Themes Most Active:**\n{themes}\n\n**Queue status:** {queue_count} engagement cards"},
        {"phase": "draft_review", "role": "user", "template": "Review these drafts: {draft_ids}"},
        {"phase": "drafts", "role": "assistant", "template": "{draft_details}"},
        {"phase": "approval", "role": "user", "template": "{approval_or_edits}"},
        {"phase": "execution", "role": "assistant", "template": "{posting_execution}"}
      ],
      "content_domains": [
        "agent_observability_threads", "openclaw_ecosystem", "trust_production",
        "ai_startup_culture", "memory_systems", "developer_tools",
        "acquisition_news", "community_builders"
      ],
      "fact_density": "medium",
      "typical_facts": ["usernames", "post_ids", "themes", "engagement_counts", "queue_sizes"]
    },

    "content_ideation": {
      "agent": "contentway",
      "message_range": [8, 14],
      "description": "Professional content brainstorming, research, and draft creation",
      "arc": [
        {"phase": "brief", "role": "user", "template": "[Subagent Task]: Content Ideation for {platform}\n\n{brief}"},
        {"phase": "identity", "role": "assistant", "template": "I'm contentway. {personality_intro}\n\n**Researching...**"},
        {"phase": "research", "role": "assistant", "template": "**Research Phase:**\n{research_findings}"},
        {"phase": "ideas", "role": "assistant", "template": "**Idea Cards Generated:**\n{idea_cards}"},
        {"phase": "feedback", "role": "user", "template": "{feedback_on_ideas}"},
        {"phase": "refine", "role": "assistant", "template": "{refined_ideas}"},
        {"phase": "draft", "role": "assistant", "template": "**Draft:**\n{draft_content}"},
        {"phase": "polish", "role": "user", "template": "{polish_instructions}"},
        {"phase": "final", "role": "assistant", "template": "{final_version}"}
      ],
      "content_domains": [
        "linkedin_thought_leadership", "technical_blog_posts", "product_updates",
        "ai_ethics_commentary", "startup_lessons", "memory_research"
      ],
      "fact_density": "medium",
      "typical_facts": ["idea_titles", "draft_counts", "platform_targets", "themes"]
    },

    "alignment_review": {
      "agent": "trustalign",
      "message_range": [6, 12],
      "description": "Post-hoc alignment review of agent actions against Alex's codex",
      "arc": [
        {"phase": "task", "role": "user", "template": "[Subagent Task]: Review this {action_type} for alignment:\n\n{action_record_json}"},
        {"phase": "load_codex", "role": "assistant", "template": "I'm TrustAlign, the alignment observer. Loading codex.json...\n\n{codex_summary}"},
        {"phase": "review", "role": "assistant", "template": "**Relevant codex entries:**\n{relevant_entries}\n\n**Alignment Assessment:**\n- Score: {score}\n{assessment}"},
        {"phase": "feedback", "role": "assistant", "template": "**Feedback:**\n{feedback_items}\n\n**{action_required_or_not}**"},
        {"phase": "daily_summary", "role": "assistant", "template": "**TrustAlign Daily Observer — {date}**\n\n**Actions reviewed:** {count}\n**Alignment Score:** {daily_score}\n\n**What worked well:**\n{positives}\n\n**Growth edge:**\n{growth_edge}\n\n**Key question:**\n> {reflective_question}"}
      ],
      "content_domains": [
        "social_engagement_review", "email_review", "task_completion_review",
        "delegation_review", "communication_style", "daily_observer"
      ],
      "fact_density": "high",
      "typical_facts": ["alignment_scores", "codex_entries_cited", "growth_edges", "recommendations"]
    },

    "tool_execution": {
      "agent": "worker",
      "message_range": [6, 12],
      "description": "Low-cost tool execution tasks with evidence-first reporting",
      "arc": [
        {"phase": "assignment", "role": "user", "template": "[Subagent Task]: {task_description}\n\nModel: zai/glm-4.7\nScope: {scope}"},
        {"phase": "plan", "role": "assistant", "template": "I'm Worker. Using GLM-4.7.\n\n**Task:** {task}\n**Output path:** {output_path}\n\n**Plan:**\n{execution_plan}"},
        {"phase": "execute", "role": "assistant", "template": "**Executing...**\n{execution_steps}"},
        {"phase": "evidence", "role": "assistant", "template": "**Evidence collected:**\n{evidence}"},
        {"phase": "verify", "role": "assistant", "template": "**Output verification:**\n{verification_checklist}"},
        {"phase": "report", "role": "assistant", "template": "**Report:**\n{summary}\n\nWork paper saved: {output_path}"}
      ],
      "content_domains": [
        "browser_automation", "api_calls", "file_operations",
        "data_gathering", "report_generation", "research_tasks"
      ],
      "fact_density": "medium",
      "typical_facts": ["tool_outputs", "file_paths", "api_responses", "error_states"]
    },

    "self_improvement": {
      "agent": "main",
      "message_range": [12, 20],
      "description": "Agent self-audit, issue identification, and improvement planning",
      "arc": [
        {"phase": "audit_request", "role": "user", "template": "Do a self-improvement review. Look at conversations from {date_range} and identify where you made mistakes or could do better."},
        {"phase": "audit", "role": "assistant", "template": "**Self-Improvement Review: {date_range}**\n\nAnalyzed conversations and identified {count} issues:\n\n{issue_table}"},
        {"phase": "details", "role": "assistant", "template": "**Details:**\n{issue_details}"},
        {"phase": "question", "role": "user", "template": "{clarification_question}"},
        {"phase": "answer", "role": "assistant", "template": "{clarification_answer}"},
        {"phase": "prioritize_request", "role": "user", "template": "Which ones should we fix first?"},
        {"phase": "prioritize", "role": "assistant", "template": "**Priority order:**\n{prioritized_list}\n\n**Quick wins:**\n{quick_wins}\n\n**Needs research:**\n{needs_research}"},
        {"phase": "fix_instruction", "role": "user", "template": "{fix_instruction}"},
        {"phase": "fix_execution", "role": "assistant", "template": "{fix_result}"},
        {"phase": "reflection", "role": "assistant", "template": "**Reflection:**\n{lessons_learned}\n\n**Commitments:**\n{commitments}"}
      ],
      "content_domains": [
        "error_patterns", "efficiency_improvements", "communication_quality",
        "tool_usage_optimization", "autonomy_boundaries", "cost_reduction"
      ],
      "fact_density": "very_high",
      "typical_facts": ["issue_descriptions", "resolutions", "commitments", "metrics_before_after"]
    }
  },

